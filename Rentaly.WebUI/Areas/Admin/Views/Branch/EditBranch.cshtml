@model Rentaly.WebUI.Areas.Admin.Models.BranchFormViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var branch = Model.Branch;
}

<main class="ml-[280px] pt-[64px] p-xl">
    <div class="max-w-2xl mx-auto">
        <h1 class="font-h1 text-h1 text-on-surface mb-xs">Şubeyi Düzenle</h1>
        <p class="font-body-md text-on-surface-variant mb-2xl">@branch.BranchName şubesinin bilgilerini güncelleyin.</p>

        <form asp-area="Admin" asp-controller="Branch" asp-action="EditBranch" method="post">
            <input type="hidden" asp-for="Branch.BranchId" />

            <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl p-xl space-y-lg">
                <div class="space-y-2">
                    <label class="font-label-md text-on-surface">Şube Adı <span class="text-primary">*</span></label>
                    <input asp-for="Branch.BranchName" class="w-full h-11 px-4 rounded-lg border border-outline-variant form-input-focus" type="text" />
                </div>

                <div class="space-y-2">
                    <label class="font-label-md text-on-surface">Şehir <span class="text-primary">*</span></label>
                    <input asp-for="Branch.City" class="w-full h-11 px-4 rounded-lg border border-outline-variant form-input-focus" type="text" />
                </div>

                <div class="space-y-2">
                    <label class="font-label-md text-on-surface">Adres</label>
                    <input asp-for="Branch.Address" class="w-full h-11 px-4 rounded-lg border border-outline-variant form-input-focus" type="text" />
                </div>

                <div class="space-y-2">
                    <label class="font-label-md text-on-surface">Yönetici Adı</label>
                    <input asp-for="Branch.ManagerName" class="w-full h-11 px-4 rounded-lg border border-outline-variant form-input-focus" type="text" />
                </div>

                <div class="flex items-center justify-between py-2">
                    <div>
                        <p class="font-label-md text-on-surface font-bold">Şube Açık</p>
                        <p class="font-label-sm text-on-surface-variant">Rezervasyona açık mı?</p>
                    </div>
                    <input asp-for="Branch.IsOpen" type="checkbox" class="w-5 h-5" />
                </div>

                @if (branch.Cars != null && branch.Cars.Any())
                {
                    <div class="pt-md border-t border-outline-variant flex items-center gap-2 text-on-surface-variant font-label-sm">
                        <span class="material-symbols-outlined text-[16px]">info</span>
                        Bu şubeye bağlı @branch.Cars.Count araç var.
                    </div>
                }
            </div>

            <div class="flex justify-between items-center mt-xl">
                <button type="submit" class="bg-[#22C55E] hover:bg-[#16A34A] text-white px-xl py-3 rounded-xl font-label-md flex items-center gap-2 transition-all shadow-sm active:scale-95">
                    <span class="material-symbols-outlined text-[20px]">check_circle</span>
                    Değişiklikleri Kaydet
                </button>
                <a asp-area="Admin" asp-controller="Branch" asp-action="Index"
                   class="px-xl py-3 rounded-xl border border-outline-variant text-on-surface font-label-md hover:bg-surface-container-low transition-all">
                    İptal
                </a>
            </div>
        </form>

        <form asp-area="Admin" asp-controller="Branch" asp-action="DeleteBranch" asp-route-id="@branch.BranchId" method="post"
              onsubmit="return confirm('Bu şubeyi silmek istediğinize emin misiniz?');" class="mt-md">
            <button type="submit" class="px-xl py-3 rounded-xl text-error font-label-md hover:bg-error/10 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">delete</span>
                Şubeyi Sil
            </button>
        </form>
    </div>
</main>