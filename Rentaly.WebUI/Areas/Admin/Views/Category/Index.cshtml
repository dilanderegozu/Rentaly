@model Rentaly.WebUI.Areas.Admin.Models.CategoryListViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="pl-[280px] min-h-screen">
    <div class="p-xl">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-md mb-2xl">
            <div>
                <h2 class="font-h1 text-h1 text-on-surface">Kategori Yönetimi</h2>
                <p class="font-body-md text-body-md text-on-surface-variant mt-xs">Araç kategorilerini ve fiyatlandırma politikalarını yönetin.</p>
            </div>
            <a asp-area="Admin" asp-controller="Category" asp-action="CreateCategory"
               class="bg-[#22C55E] hover:bg-[#16A34A] text-white px-xl py-md rounded-lg font-label-md text-label-md flex items-center gap-sm transition-all shadow-sm active:scale-95">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Yeni Kategori Ekle
            </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-xl mb-2xl">
            <div class="bg-surface-container-lowest p-xl rounded-2xl border border-outline-variant card-shadow">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-md">
                    <span class="material-symbols-outlined">category</span>
                </div>
                <p class="text-on-surface-variant font-label-md text-label-md">Toplam Kategori</p>
                <h3 class="text-display font-display text-on-surface">@Model.TotalCategoryCount</h3>
            </div>
            <div class="bg-surface-container-lowest p-xl rounded-2xl border border-outline-variant card-shadow">
                <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary mb-md">
                    <span class="material-symbols-outlined">directions_car</span>
                </div>
                <p class="text-on-surface-variant font-label-md text-label-md">Müsait Araçlar</p>
                <h3 class="text-display font-display text-on-surface">@Model.TotalActiveCarCount</h3>
            </div>
            <div class="bg-surface-container-lowest p-xl rounded-2xl border border-outline-variant card-shadow">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-md">
                    <span class="material-symbols-outlined">payments</span>
                </div>
                <p class="text-on-surface-variant font-label-md text-label-md">Ortalama Günlük Fiyat</p>
                <h3 class="text-display font-display text-on-surface">@Model.AverageDailyPrice.ToString("C0")</h3>
            </div>
        </div>

        <!-- Category Grid -->
        @if (Model.Rows.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-xl">
                @foreach (var row in Model.Rows)
                {
                    <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl overflow-hidden card-shadow group">
                        <div class="relative h-48 bg-surface-container-low overflow-hidden flex items-center justify-center">
                            @if (!string.IsNullOrEmpty(row.ImageUrl))
                            {
                                <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="@row.ImageUrl" alt="@row.CategoryName" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-[48px] text-outline">@row.IconName</span>
                            }

                            <div class="absolute top-md right-md px-md py-sm bg-white/90 backdrop-blur-md rounded-full font-label-sm text-label-sm flex items-center gap-xs">
                                <span class="w-2 h-2 rounded-full @(row.IsActive ? "bg-[#22C55E]" : "bg-on-surface-variant/40")"></span>
                                @(row.IsActive ? "Aktif" : "Pasif")
                            </div>
                        </div>
                        <div class="p-xl">
                            <div class="flex items-center gap-sm mb-sm">
                                <span class="material-symbols-outlined text-primary">@row.IconName</span>
                                <h4 class="font-h3 text-h3">@row.CategoryName</h4>
                            </div>
                            <p class="text-body-sm text-on-surface-variant mb-xl">@row.Description</p>

                            <div class="flex justify-between items-end border-t border-outline-variant pt-xl">
                                <div>
                                    <p class="text-label-sm text-on-surface-variant uppercase tracking-tighter">Taban Fiyat</p>
                                    <p class="text-h2 font-h2 text-primary">@row.BasePrice.ToString("C0")<span class="text-body-sm text-on-surface-variant font-normal"> /gün</span></p>
                                </div>
                                <div class="text-right">
                                    <p class="text-label-sm text-on-surface-variant uppercase tracking-tighter">Araç Sayısı</p>
                                    <p class="font-h3 text-h3">@row.CarCount</p>
                                </div>
                            </div>

                            <div class="mt-xl flex gap-md">
                                <a asp-area="Admin" asp-controller="Category" asp-action="EditCategory" asp-route-id="@row.CategoryId"
                                   class="flex-1 border border-outline-variant py-sm rounded-lg font-label-md text-label-md hover:bg-surface-container-low transition-colors flex items-center justify-center gap-xs">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Düzenle
                                </a>
                                <form asp-area="Admin" asp-controller="Category" asp-action="DeleteCategory" asp-route-id="@row.CategoryId" method="post"
                                      onsubmit="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="p-sm rounded-lg border border-outline-variant hover:bg-error/5 hover:text-error hover:border-error/20 transition-all text-on-surface-variant">
                                        <span class="material-symbols-outlined text-[18px]">delete</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-surface-container-lowest border border-dashed border-outline-variant rounded-2xl p-2xl flex flex-col items-center justify-center text-center">
                <span class="material-symbols-outlined text-[32px] text-outline mb-md">category</span>
                <h3 class="font-h3 text-h3 mb-xs">Henüz kategori eklenmemiş</h3>
                <p class="text-on-surface-variant mb-lg">Araçlarını sınıflandırmak için ilk kategoriyi oluştur.</p>
                <a asp-area="Admin" asp-controller="Category" asp-action="CreateCategory"
                   class="bg-[#22C55E] hover:bg-[#16A34A] text-white px-lg py-2.5 rounded-xl font-label-md flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">add</span>
                    İlk Kategoriyi Ekle
                </a>
            </div>
        }

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="mt-2xl bg-surface-container-lowest rounded-2xl border border-outline-variant card-shadow p-xl flex justify-between items-center">
                <p class="text-body-sm text-on-surface-variant">
                    Toplam @Model.TotalCategoryCount kategoriden
                    @(((Model.CurrentPage - 1) * Model.PageSize) + 1)-@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCategoryCount)) arası gösteriliyor.
                </p>
                <div class="flex gap-sm">
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                       class="w-10 h-10 flex items-center justify-center border border-outline-variant rounded-lg hover:bg-surface-container-low transition-colors @(Model.CurrentPage <= 1 ? "opacity-50 pointer-events-none" : "")">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </a>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-area="Admin" asp-controller="Category" asp-action="Index" asp-route-page="@i"
                           class="w-10 h-10 flex items-center justify-center rounded-lg @(i == Model.CurrentPage ? "bg-primary text-white" : "border border-outline-variant hover:bg-surface-container-low")">
                            @i
                        </a>
                    }
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                       class="w-10 h-10 flex items-center justify-center border border-outline-variant rounded-lg hover:bg-surface-container-low transition-colors @(Model.CurrentPage >= Model.TotalPages ? "opacity-50 pointer-events-none" : "")">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </a>
                </div>
            </div>
        }
    </div>
</main>

<style>
    .card-shadow {
        box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.05);
    }
</style>