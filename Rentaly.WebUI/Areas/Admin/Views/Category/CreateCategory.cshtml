@model Rentaly.WebUI.Areas.Admin.Models.CategoryFormViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="pl-[280px] min-h-screen">
    <div class="p-xl max-w-2xl mx-auto">
        <h1 class="font-h1 text-h1 text-on-surface mb-xs">Yeni Kategori Ekle</h1>
        <p class="font-body-md text-on-surface-variant mb-2xl">Araçlarınızı sınıflandırmak için yeni bir kategori tanımlayın.</p>

        <form asp-area="Admin" asp-controller="Category" asp-action="CreateCategory" method="post">
            <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl p-xl space-y-lg">
                <div class="space-y-2">
                    <label class="font-label-md text-on-surface">Kategori Adı <span class="text-primary">*</span></label>
                    <input asp-for="Category.CategoryName" class="w-full h-11 px-4 rounded-lg border border-outline-variant form-input-focus" placeholder="Örn: SUV" type="text" />
                </div>

                <div class="space-y-2">
                    <label class="font-label-md text-on-surface">Açıklama</label>
                    <textarea asp-for="Category.Description" rows="3" class="w-full p-4 rounded-lg border border-outline-variant form-input-focus resize-none" placeholder="Kategori hakkında kısa açıklama..."></textarea>
                </div>

                <div class="space-y-2">
                    <label class="font-label-md text-on-surface">İkon (Material Symbols adı)</label>
                    <input asp-for="Category.IconName" class="w-full h-11 px-4 rounded-lg border border-outline-variant form-input-focus" placeholder="Örn: landscape, eco, diamond" type="text" />
                    <p class="font-label-sm text-on-surface-variant">Google Material Symbols ikon isimlerinden biri (örn. eco, landscape, workspace_premium, diamond).</p>
                </div>

                <div class="flex items-center justify-between py-2">
                    <div>
                        <p class="font-label-md text-on-surface font-bold">Aktif Kategori</p>
                        <p class="font-label-sm text-on-surface-variant">Listelerde gösterilsin mi?</p>
                    </div>
                    <input asp-for="Category.IsActive" type="checkbox" class="w-5 h-5" checked />
                </div>
            </div>

            <div class="flex justify-end gap-md mt-xl">
                <a asp-area="Admin" asp-controller="Category" asp-action="Index"
                   class="px-xl py-3 rounded-xl border border-outline-variant text-on-surface font-label-md hover:bg-surface-container-low transition-all">
                    İptal
                </a>
                <button type="submit" class="bg-[#22C55E] hover:bg-[#16A34A] text-white px-xl py-3 rounded-xl font-label-md flex items-center gap-2 transition-all shadow-sm active:scale-95">
                    <span class="material-symbols-outlined text-[20px]">check_circle</span>
                    Kategoriyi Kaydet
                </button>
            </div>
        </form>
    </div>
</main>