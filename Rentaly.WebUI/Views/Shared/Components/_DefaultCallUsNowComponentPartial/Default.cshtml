@model List<Rentaly.EntityLayer.Entities.Contact>
<section id="section-call-to-action" class="bg-color-2 pt60 pb60 text-light">
	<div class="container">
		<div class="row align-items-center">
			<div class="col-lg-4 offset-lg-2">
				<span class="subtitle text-white">Daha fazla bilgi için bizi arayın.</span>
				<h2 class="s2">Rentaly müşteri hizmetleri her zaman size yardımcı olmak için burada.</h2>
			</div>
			@foreach (var item in Model)
			{
				<div class="col-lg-4 text-lg-center text-sm-center">
					<div class="phone-num-big">
					<i class="fa fa-phone"></i>
					<span class="pnb-text">ŞİMDİ BİZİ ARAYIN</span>
					<span class="pnb-num">@item.Phone</span>
				</div>
				<a href="#" class="btn-main">İletişim Kurun</a>
			</div>
			}
		</div>
	</div>
</section>
