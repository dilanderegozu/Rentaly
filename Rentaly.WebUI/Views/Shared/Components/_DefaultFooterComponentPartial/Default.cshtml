@model List<Rentaly.EntityLayer.Entities.Contact>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
    footer {
        padding: 60px 0 0 0 !important;
        background-color: #111111 !important;
        color: #eeeeee !important;
    }

        footer h5 {
            color: #ffffff !important;
            font-weight: 700;
            margin-bottom: 25px;
        }

        footer ul {
            list-style: none;
            padding: 0;
        }

            footer ul li {
                margin-bottom: 10px;
            }

                footer ul li a {
                    color: rgba(255,255,255,0.6) !important;
                    text-decoration: none;
                    transition: 0.3s;
                }

                    footer ul li a:hover {
                        color: #26d120 !important;
                    }

    address.s1 {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

        address.s1 .contact-row {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            color: rgba(255,255,255,0.6);
        }

        address.s1 i {
            color: #26d120 !important;
            margin-top: 3px;
        }

        address.s1 a {
            color: rgba(255,255,255,0.6);
            text-decoration: none;
        }

    .subfooter {
        padding: 15px 0 !important;
        border-top: 1px solid rgba(255, 255, 255, 0.05) !important;
        background-color: #111111 !important;
        margin-top: 50px;
    }

    .footer-flex-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .footer-copyright {
        font-size: 13px;
        color: #ffffff;
        opacity: 0.8;
    }

        .footer-copyright a {
            color: #ffffff;
            text-decoration: none;
        }

    .footer-simple-menu {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 30px;
    }

        .footer-simple-menu li a {
            color: #ffffff !important;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
        }

    .scroll-to-top-btn {
        background-color: #26d120 !important;
        color: white !important;
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 5px;
        text-decoration: none;
    }
</style>

@{
    var contact = Model != null && Model.Any() ? Model.First() : null;
}

<footer class="text-light">
    <div class="container">
        <div class="row g-custom-x">
            <div class="col-lg-3">
                <div class="widget">
                    <h5>Rentaly Hakkında</h5>
                    <p>Kalite ve uygun fiyatın buluştuğu yer. Aşırı maliyetlerin yükü olmadan, sorunsuz ve keyifli bir yolculuğun önemini anlıyoruz.</p>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="widget">
                    <h5>İletişim Bilgileri</h5>
                    <address class="s1">
                        <div class="contact-row">
                            <i class="fa fa-map-marker"></i>
                            <span>@(contact?.Address ?? "Bağdat Caddesi, No:45, Kadıköy, İstanbul")</span>
                        </div>
                        <div class="contact-row">
                            <i class="fa fa-phone"></i>
                            <span>@(contact?.Phone ?? "+90 216 123 45 67")</span>
                        </div>
                        <div class="contact-row">
                            <i class="fa fa-envelope-o"></i>
                            <a href="mailto:@(contact?.Email ?? "iletisim@rentaly.com")">@(contact?.Email ?? "iletisim@rentaly.com")</a>
                        </div>
                    </address>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="widget">
                    <h5>Hızlı Linkler</h5>
                    <ul>
                        <li><a href="/Default/Index/">Ana Sayfa</a></li>
                        <li><a href="/NewsLatter/Index/">Haberler</a></li>
                        <li><a href="/Car/Index/">Arabalar</a></li>
                        <li><a href="/Booking/Index/">Rezervasyon</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="widget">
                    <h5>Sosyal Medyalarımız</h5>
                    <div class="social-icons" style="display: flex; gap: 15px;">
                        <a href="https://www.instagram.com" target="_blank">
                            <i class="fa-brands fa-instagram fa-lg"></i>
                        </a>

                        <a href="https://www.linkedin.com" target="_blank">
                            <i class="fa-brands fa-linkedin fa-lg"></i>
                        </a>

                        <a href="https://x.com" target="_blank">
                            <i class="fa-brands fa-x-twitter fa-lg"></i>
                        </a>

                        <a href="https://www.youtube.com" target="_blank">
                            <i class="fa-brands fa-youtube fa-lg"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="subfooter">
        <div class="container">
            <div class="footer-flex-container">
                <div class="footer-copyright">
                    Telif hakkı 2025 Rentaly by Designesia'ya aittir.
                </div>

                <div class="d-flex align-items-center" style="gap: 40px;">
                    <ul class="footer-simple-menu">
                        <li><a href="#">Şartlar ve Koşullar</a></li>
                        <li><a href="#">Gizlilik Politikası</a></li>
                    </ul>

                    <a href="#" class="scroll-to-top-btn">
                        <i class="fa fa-chevron-up"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</footer>