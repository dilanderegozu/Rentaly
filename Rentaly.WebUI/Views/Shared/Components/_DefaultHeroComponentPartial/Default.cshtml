@model Rentaly.WebUI.Models.HeroViewModel

﻿<style>
     #section-hero {
         padding: 130px 0 0 0 !important;
         min-height: 900px;
     }

     .jarallax-img {
         z-index: -1 !important;
         object-fit: cover !important;
     }

  
     .hero-search-form {
         background: white !important;
         border-radius: 12px !important;
         padding: 20px !important;
         box-shadow: 0px 10px 40px rgba(0,0,0,0.2) !important;
         max-width: 1050px;
         margin: 0 auto;
         position: relative;
         z-index: 10;
     }

     .form-title {
         color: #1c355e !important;
         font-weight: 700 !important;
         font-size: 13px !important;
         margin-bottom: 8px !important;
         display: block;
     }


     .v-selection-group {
         display: flex;
         gap: 10px;
     }

     .v-type {
         flex: 1;
         display: flex;
     }

         .v-type input {
             display: none;
         }

         .v-type label {
             display: flex;
             flex-direction: column;
             align-items: center;
             justify-content: center;
             background-color: #26d120 !important; 
             color: white;
             width: 100%;
             aspect-ratio: 1 / 1;
             border-radius: 10px;
             cursor: pointer;
             padding: 10px;
             transition: 0.3s;
             margin: 0;
         }

             .v-type label img {
                 width: 45px;
                 height: auto;
                 margin-bottom: 8px;
                 filter: brightness(0) invert(1);
             }

             .v-type label span {
                 font-weight: 700;
                 font-size: 12px;
             }

         .v-type input:checked + label {
             background-color: #1a9e16 !important;
             transform: scale(0.98);
             box-shadow: inset 0 0 5px rgba(0,0,0,0.2);
         }

   
     .custom-input {
         border: 1px solid #ced4da !important;
         height: 38px !important;
         font-size: 13px !important;
         border-radius: 5px !important;
     }

     .input-group-custom {
         display: flex;
         width: 100%;
     }

     .date-field {
         flex: 2;
         border-top-right-radius: 0 !important;
         border-bottom-right-radius: 0 !important;
     }

     .time-field {
         flex: 1;
         border-left: none !important;
         border-top-left-radius: 0 !important;
         border-bottom-left-radius: 0 !important;
     }

     .btn-search {
         background: #26d120 !important;
         color: white !important;
         border: none;
         padding: 8px 25px;
         font-weight: 700;
         border-radius: 6px;
         font-size: 14px;
     }


     .steps-container {
         margin-top: 60px;
         color: white;
     }

     .step-box {
         position: relative;
         padding-right: 15px;
     }

     .step-num {
         background: #26d120;
         width: 32px;
         height: 32px;
         display: flex;
         align-items: center;
         justify-content: center;
         font-weight: 800;
         border-radius: 5px;
         margin-bottom: 15px;
     }

     .step-box h4 {
         font-size: 18px;
         font-weight: 700;
         color: white;
         margin-bottom: 8px;
     }

     .step-box p {
         font-size: 13px;
         opacity: 0.8;
         line-height: 1.5;
     }
</style>

<section id="section-hero" class="jarallax">
    <img src="/RentalyHTML/images/background/1.jpg" class="jarallax-img" alt="">

    <div class="container">

        <div class="row">
            <div class="col-lg-12 text-center text-light mb-4">
                <h2 style="font-weight: 800;">
                    Bir <span class="id-color">araç</span> mı arıyorsun?
                </h2>
            </div>
        </div>

        <div class="hero-search-form">

            <form method="get" action="/Car/Index">

                <div class="row g-3">

                
                    <div class="col-lg-5">
                        <span class="form-title">Araç Tipi Seç</span>

                        <div class="v-selection-group">

                            @{
                                bool isFirstType = true;
                            }
                            @foreach (var item in Model.VehicleTypes)
                            {
                                <div class="v-type">
                                    <input id="vtype-@item.VehicleTypeId" name="VehicleTypeIds" type="radio"
                                           value="@item.VehicleTypeId" @(isFirstType ? "checked" : "")>
                                    <label for="vtype-@item.VehicleTypeId">
                                        <img src="@item.IconUrl">
                                        <span>@item.VehicleTypeName</span>
                                    </label>
                                </div>
                                isFirstType = false;
                            }

                          
                        </div>
                    </div>

          
                    <div class="col-lg-7">
                        <div class="row g-2">

                            <div class="col-6">
                                <span class="form-title">Alış Lokasyonu</span>

                                <select name="pickUpBranchId" class="form-control custom-input">
                                    <option value="">Lokasyon Seçiniz</option>

                                    @foreach (var item in Model.Branches)
                                    {
                                        <option value="@item.BranchId">
                                            @item.BranchName
                                        </option>
                                    }
                                </select>
                            </div>

                        
                            <div class="col-6">
                                <span class="form-title">Teslim Lokasyonu</span>

                                <select name="dropOffBranchId" class="form-control custom-input">
                                    <option value="">Lokasyon Seçiniz</option>

                                    @foreach (var item in Model.Branches)
                                    {
                                        <option value="@item.BranchId">
                                            @item.BranchName
                                        </option>
                                    }
                                </select>
                            </div>

                      
                            <div class="col-6">
                                <span class="form-title">Alış Tarihi</span>

                                <div class="input-group-custom">
                                    <input type="date" name="pickUpDate" class="form-control custom-input date-field">

                                    <select name="pickUpTime" class="form-select custom-input time-field">
                                        <option>09:00</option>
                                        <option>12:00</option>
                                        <option>15:00</option>
                                    </select>
                                </div>
                            </div>

             
                            <div class="col-6">
                                <span class="form-title">Teslim Tarihi</span>

                                <div class="input-group-custom">
                                    <input type="date" name="dropOffDate" class="form-control custom-input date-field">

                                    <select name="dropOffTime" class="form-select custom-input time-field">
                                        <option>09:00</option>
                                        <option>12:00</option>
                                        <option>15:00</option>
                                    </select>
                                </div>
                            </div>

                        </div>
                    </div>

          
                    <div class="col-12 text-end mt-3">
                        <button type="submit" class="btn-search">
                            Araç Bul
                        </button>
                    </div>

                </div>

            </form>
        </div>

        @await Component.InvokeAsync("DefaultStepsComponentPartial")

    </div>
</section>