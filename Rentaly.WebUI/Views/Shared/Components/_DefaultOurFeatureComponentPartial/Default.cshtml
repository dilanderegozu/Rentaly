@model Rentaly.EntityLayer.Entities.OurFeature
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<section aria-label="section">
	<div class="container">
		@if (Model == null)
		{
			<p>Veri bulunamadı.</p>
			return;
		}
		<div class="row align-items-center">
			<div class="col-lg-6 offset-lg-3 text-center">
				<h2>Özelliklerimiz</h2>
				<p> @Model.Title </p>
				<div class="spacer-20"></div>
			</div>
			<div class="clearfix"></div>
			<div class="col-lg-3">
				<div class="box-icon s2 p-small mb20 wow fadeInRight" data-wow-delay=".5s">
					<i class="@Model.Icon1"></i>
					<div class="d-inner">
						<h4>@Model.Title1</h4>
						@Model.Description1
					</div>
				</div>
				<div class="box-icon s2 p-small mb20 wow fadeInL fadeInRight" data-wow-delay=".75s">
					<i class="@Model.Icon2"></i>
					<div class="d-inner">
						<h4>@Model.Title2</h4>
						@Model.Description2
					</div>
				</div>
			</div>

			<div class="col-lg-6">
				<img src="@Model.ImageUrl" alt="" class="img-fluid wow fadeInUp">
			</div>

			<div class="col-lg-3">
				<div class="box-icon s2 d-invert p-small mb20 wow fadeInL fadeInLeft" data-wow-delay="1s">
					<i class="@Model.Icon3"></i>
					<div class="d-inner">
						<h4>@Model.Title3</h4>
						@Model.Description3
					</div>
				</div>
				<div class="box-icon s2 d-invert p-small mb20 wow fadeInL fadeInLeft" data-wow-delay="1.25s">
					<i class="@Model.Icon4"></i>
					<div class="d-inner">
						<h4>@Model.Title4</h4>
						@Model.Description4
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
<style>
	.box-icon i {
		color: green !important; 
		display: inline-block !important;
		font-size: 32px;
		margin-bottom: 10px;
	}
</style>