@model List<Rentaly.EntityLayer.Entities.Brand>

<section aria-label="section" class="brand-section">
	<div class="brand-marquee">

		<div class="brand-track">
			@for (int i = 0; i < 2; i++)
			{
				@foreach (var item in Model)
				{
					<div class="brand-item">
						<span>@item.BrandName</span>
						<i class="fa-solid fa-circle"></i>
					</div>
				}
			}
		</div>

	</div>
</section>
<style>
    .brand-section {
        background: #111;
        overflow: hidden;
        padding: 18px 0;
    }

    .brand-marquee {
        overflow: hidden;
        width: 100%;
    }

    .brand-track {
        display: flex;
        width: max-content;
        animation: marquee 30s linear infinite;
    }

    .brand-item {
        display: flex;
        align-items: center;
        margin-right: 45px;
        flex-shrink: 0;
    }

        .brand-item span {
            font-size: 18px;
            font-weight: 700;
            color: #26d120;
            letter-spacing: .5px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .brand-item i {
            color: #26d120;
            font-size: 7px;
            margin-left: 45px;
        }

    @@keyframes marquee {
        from {
            transform: translateX(0);
        }

        to {
            transform: translateX(-50%);
        }
    }
</style>